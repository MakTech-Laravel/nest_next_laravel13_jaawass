# =============================================================================
# SourceNest API (Laravel 13)
# Copy to .env and fill in values. Never commit .env with real secrets.
# =============================================================================

APP_NAME=SourceNest
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_SUPPORTED_LOCALES=en,ar,he,zh_CN
# APP_LOCALE_HEADER=X-App-Locale
# APP_LOCALE_HEADER_ENABLED=true

# APP_ENABLED_CURRENCIES=USD,EUR,SAR
# APP_BASE_CURRENCY=USD
# APP_CURRENCY_HEADER=X-App-Currency
# APP_CURRENCY_HEADER_ENABLED=true
# CURRENCY_CACHE_TTL=120
# CURRENCY_FX_SYNC_ENABLED=false
# CURRENCY_FX_ALLOWED_HOSTS=api.frankfurter.app
# CURRENCY_FX_TIMEOUT=10

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database ---
# Local dev: sqlite (default) or mysql
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=sourcenest
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Use "pusher" with PUSHER_* below for realtime; "log" or "null" for local/CI without Pusher.
BROADCAST_CONNECTION=log

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# Use "public" in production so uploaded files (articles, products) are web-accessible after storage:link
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (Mailgun API — primary transport via MailingService + queue jobs) ---
MAILGUN_DOMAIN=
MAILGUN_SECRET=
# US: https://api.mailgun.net | EU: https://api.eu.mailgun.net
MAILGUN_ENDPOINT=https://api.mailgun.net
MAILING_QUEUE=default
MAILING_JOB_DELAY_SECONDS=1

MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Legacy SMTP (optional fallback)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=

# --- AWS S3 (optional — cloud file storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- PayPal (subscription payments) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# --- Stripe (optional) ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# --- OAuth (redirect URIs must match APP_URL) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/facebook/callback

# --- Google Cloud Translation ---
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_TRANSLATE_PROJECT_ID=
GOOGLE_TRANSLATE_LOCATION=global
# Absolute path to service account JSON, or path relative to project root
GOOGLE_TRANSLATE_CREDENTIALS=
GOOGLE_TRANSLATE_MODE=v2
TRANSLATION_SOURCE_LOCALE=en
TRANSLATION_AUTO_DETECT=true
TRANSLATION_CACHE_ENABLED=true
TRANSLATION_CACHE_STORE=database
TRANSLATION_CACHE_TTL=604800
TRANSLATION_QUEUE_ENABLED=true
TRANSLATION_QUEUE_CONNECTION=database
TRANSLATION_QUEUE_NAME=translations

# --- Subscriptions ---
SUBSCRIPTION_EXPIRY_REMINDER_DAYS=7
SUBSCRIPTION_QUEUE=default
SUBSCRIPTION_PLANS_PATH=/plans
SUBSCRIPTION_AUTO_RENEW_ENABLED=true
SUBSCRIPTION_AUTO_RENEW_MAX_ATTEMPTS=3
SUBSCRIPTION_AUTO_RENEW_RETRY_HOURS=24

# --- Account / auth TTLs ---
ACCOUNT_DELETION_GRACE_DAYS=30
ACCOUNT_RESTORE_OTP_TTL_MINUTES=15
ACCOUNT_RESTORE_OTP_RESEND_SECONDS=60
PASSWORD_RESET_OTP_TTL_MINUTES=15
PASSWORD_RESET_OTP_RESEND_SECONDS=60
TWO_FACTOR_LOGIN_TOKEN_TTL_MINUTES=5
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=10
EMAIL_VERIFICATION_RESEND_SECONDS=60

# --- Messaging & uploads ---
MESSAGING_UNIQUE_TWO_PARTICIPANTS=true
MESSAGING_UNIQUE_GROUP_PARTICIPANTS=false
MANUFACTURER_ADDITIONAL_INFO_EXPIRES_DAYS=7
# MANUFACTURER_ADDITIONAL_INFO_MAX_VIDEO_KB=51200
# MANUFACTURER_ADDITIONAL_INFO_MAX_IMAGE_KB=10240
# MANUFACTURER_ADDITIONAL_INFO_MAX_AUDIO_KB=20480
# MANUFACTURER_ADDITIONAL_INFO_MAX_DOCUMENT_KB=10240

# --- Notifications ---
# NOTIFICATIONS_ENFORCE_PREFERENCES=true
# NOTIFICATIONS_OPTIONAL_DEFAULT_ENABLED=true
# NOTIFICATIONS_ALLOW_TEST_BROADCAST_ROUTE=false

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Laravel Passport — after deploy run: php artisan passport:keys
# Optional: load keys from env instead of files (see https://laravel.com/docs/13.x/passport)
# PASSPORT_PRIVATE_KEY=
# PASSPORT_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Production checklist:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# DB_CONNECTION=mysql
# FILESYSTEM_DISK=public
# BROADCAST_CONNECTION=pusher
# PAYPAL_MODE=live
# GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/v1/auth/google/callback
# FACEBOOK_REDIRECT_URI=https://api.yourdomain.com/api/v1/auth/facebook/callback
#
# After deploy:
#   php artisan key:generate
#   php artisan migrate --force
#   php artisan passport:keys
#   php artisan storage:link
#   php artisan config:cache
#   php artisan queue:work --queue=default,translations
